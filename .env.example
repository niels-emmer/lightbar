# Copy to .env and fill in values
ANTHROPIC_API_KEY=sk-ant-...

# Device (defaults match the lightbar — only change if it moves)
DEVICE_ID=your-tuya-device-id
DEVICE_IP=192.168.x.x
DEVICE_KEY=your-local-encryption-key
DEVICE_VERSION=3.5

# AI
AI_MODEL=claude-haiku-4-5-20251001
EXPERIMENT_INTERVAL_MINUTES=7

# Weather location (Amsterdam defaults)
WEATHER_LAT=52.37   # your latitude
WEATHER_LON=4.89    # your longitude
